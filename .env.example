# LI.FI Composer
LIFI_API_KEY=
LIFI_COMPOSER_BASE_URL=https://ethglobal-composer.li.quest
COMPOSER_SIGNER_ADDRESS=

# Dynamic server wallet
DYNAMIC_AUTH_TOKEN=
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_WALLET_PASSWORD=
DYNAMIC_WALLET_METADATA_JSON=
DYNAMIC_WALLET_METADATA_PATH=.circuitbreaker-wallet/wallet-metadata.json
MISSION_SIGNING_SECRET=

# EVM
BASE_RPC_URL=https://mainnet.base.org

# Ledger Wallet Provider (browser-visible by design)
NEXT_PUBLIC_LEDGER_API_KEY=
NEXT_PUBLIC_LEDGER_DAPP_IDENTIFIER=circuitbreaker
NEXT_PUBLIC_LEDGER_ENVIRONMENT=staging
NEXT_PUBLIC_DEMO_READ_ONLY=true

# Later milestones
LEDGER_APPROVER_ADDRESS=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-mini
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
